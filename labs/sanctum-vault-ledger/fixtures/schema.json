{
  "$id": "sanctum-vault-ledger.synthetic.schema.json",
  "title": "Sanctum Vault Ledger synthetic fixture bundle",
  "oneOf": [
    { "$ref": "#/$defs/vaultDocument" },
    { "$ref": "#/$defs/policiesDocument" },
    { "$ref": "#/$defs/lineageDocument" }
  ],
  "$defs": {
    "vaultDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "as_of", "secrets"],
      "properties": {
        "synthetic": { "const": true },
        "as_of": { "type": "string", "format": "date-time" },
        "secrets": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/secretRecord" }
        }
      }
    },
    "secretRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "scope", "sealed", "version", "state", "created_at", "rotates_at"],
      "properties": {
        "id": { "type": "string", "pattern": "^seal-[a-z]+-[0-9]{2}$" },
        "label": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "sealed": { "const": true },
        "version": { "type": "integer", "minimum": 1 },
        "state": { "enum": ["active", "expiring", "expired", "revoked"] },
        "created_at": { "type": "string", "format": "date-time" },
        "rotates_at": { "type": "string", "format": "date-time" }
      }
    },
    "policiesDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "scopes"],
      "properties": {
        "synthetic": { "const": true },
        "scopes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/policyRecord" }
        }
      }
    },
    "policyRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "label", "description"],
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "lineageDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic", "entries_by_secret"],
      "properties": {
        "synthetic": { "const": true },
        "entries_by_secret": {
          "type": "object",
          "minProperties": 8,
          "maxProperties": 8,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/lineageEntry" }
          }
        }
      }
    },
    "lineageEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "at", "actor"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "at": { "type": "string", "format": "date-time" },
        "actor": { "type": "string", "pattern": "^persona-(ash|briar|cinder|dune|flint)$" }
      }
    }
  }
}
